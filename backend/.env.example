# Google Gemini API (Vision + Text Analysis) - FREE TIER AVAILABLE
# Get API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (Llama 3.3 for Text Generation)
# Get API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Tavily (web search for trend agent) - OPTIONAL, 50 free searches/month
# Get API key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# App
APP_ENV=development
APP_PORT=8000
MAX_FILE_SIZE_MB=50
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/webm,video/x-msvideo
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# CORS — set to your Next.js frontend URL
CORS_ORIGINS=http://localhost:3000
